# TransIntent 환경변수 예시 — 복사해서 .env.local 로 사용

# 목 먼저: 1이면 API 키 없이 결정적 목 생성 사용(개발 기본).
# 0으로 두고 OPENAI_API_KEY를 채우면 실제 OpenAI로 동작.
MOCK_LLM=1

# 실제 생성 사용 시: MOCK_LLM=0 으로 두고 아래 키를 채운다. 서버 전용 — 브라우저 노출 금지.
# (MOCK_LLM=1 이거나 키가 비면 라우트는 자동으로 목으로 분기한다.)
# OPENAI_API_KEY=sk-...
# MODEL_GENERATE=gpt-4.1
# MODEL_QUESTIONS=gpt-4.1-mini
